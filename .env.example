# ── Telegram ──────────────────────────────────────────────────────────────────
# Get from https://my.telegram.org → API Development Tools
API_ID=12345678
API_HASH=abcdef1234567890abcdef1234567890

# Get from @BotFather → /newbot
BOT_TOKEN=1234567890:ABCDefGhIjKlMnOpQrStUvWxYz

# Your bot's @username WITHOUT the @
BOT_USERNAME=YourAnimeBot

# Comma-separated Telegram user IDs of admins
# Get your ID from @userinfobot
ADMIN_IDS=123456789,987654321

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Create free cluster at https://cloud.mongodb.com
# Connection string → Drivers → Python
MONGO_URI=mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
DB_NAME=animebot

# ── Webhook / Server ──────────────────────────────────────────────────────────
# Your Render service public URL (set after first deploy)
# Example: https://anime-bot-xxxx.onrender.com
WEBHOOK_URL=https://your-service-name.onrender.com

# Port — Render sets this automatically; 8000 for local dev
PORT=8000
